# Code Hammer environment example
# Copy this file to .env or .env.local and replace placeholder values.
# Never commit real secrets.

# Runtime
NODE_ENV=development

# Web app
WEB_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# API
API_PORT=3001
API_URL=http://127.0.0.1:3001

# Authentication and cookies
# Generate a long random value before production use.
SESSION_SECRET=replace-with-a-long-random-session-secret
COOKIE_NAME=ch_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=code_hammer
POSTGRES_PASSWORD=code_hammer_password
POSTGRES_DATABASE=code_hammer
POSTGRES_SSL=false
ADMIN_EMAIL=admin@codehammer.local
ADMIN_PASSWORD=strong-password
ADMIN_NAME=Code Hammer Admin

# Queue and cache
REDIS_URL=redis://127.0.0.1:6379

# Vector database
MILVUS_URL=http://127.0.0.1:19530
MILVUS_DATABASE=default
MILVUS_COLLECTION_PREFIX=code_hammer

# AI gateway and model providers
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=replace-with-litellm-api-key
OPENAI_API_KEY=replace-with-openai-api-key
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
GEMINI_API_KEY=replace-with-gemini-api-key

# Object storage for uploaded documents
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=ap-southeast-1
S3_BUCKET=code-hammer-local
S3_ACCESS_KEY_ID=replace-with-access-key
S3_SECRET_ACCESS_KEY=replace-with-secret-key

# Email notifications
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@codehammer.local

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
LOG_LEVEL=info
